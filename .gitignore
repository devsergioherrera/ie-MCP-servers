# =====================================================================
# IE-MCP-Servers — .gitignore
# =====================================================================

# Secretos / variables de entorno
deploy/.env
.env
*.env.local

# Backups generados por el MCP de docs (write_doc)
docs/*.md.bak

# Logs runtime de los contenedores (volumen montado)
logs/
*.jsonl
*.jsonl.*

# Caches Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Build artifacts
*.log
.dockerignore

# IDE
.vscode/
.idea/
*.swp

# Claude Code local settings (mantener .claude/skills/ y .claude/commands/ en el repo)
.claude/settings.local.json
