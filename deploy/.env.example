# =====================================================================
# IE-MCP-Servers — Variables de entorno
# Copiar a `.env` (gitignored) y completar con valores reales.
# =====================================================================

# SQL Server — BD SIE (logistica)
# El usuario `mcp_reader` debe tener GRANT SELECT sobre dbo.CAMION_X_DIA.
MSSQL_SIE_CONN=Server=<HOST>,1433;Database=SIE;User ID=mcp_reader;Password=<PASSWORD>;Encrypt=true;TrustServerCertificate=true

# SQL Server — BD EMPAQUE(PR) (empaque)
# El usuario `mcp_reader` debe tener GRANT SELECT sobre dbo.vw_EtiquetasBI.
# OJO con el nombre con parentesis: SqlClient lo acepta literal.
MSSQL_EMPAQUE_CONN=Server=<HOST>,1433;Database=EMPAQUE(PR);User ID=mcp_reader;Password=<PASSWORD>;Encrypt=true;TrustServerCertificate=true

# SQL Server — BD IE_MONITOR (monitoreo) en host 192.168.50.86
# OTRO servidor SQL Server, no el mismo que SIE/EMPAQUE.
# Esta connection string usa mcp_writer (db_datareader + db_datawriter)
# porque las 5 entidades de IE_MONITOR estan habilitadas para escritura.
# Ver data-mcp-servers/mssql/grants-monitor.sql
MSSQL_MONITOR_CONN=Server=192.168.50.86,1433;Database=IE_MONITOR;User ID=mcp_writer;Password=<PASSWORD>;Encrypt=true;TrustServerCertificate=true

# SQL Server — BD INTRANET (intranet) en host 192.168.50.86 (mismo host que IE_MONITOR)
# SOLO LECTURA con mcp_reader (db_datareader sobre toda la BD).
# El LOGIN mcp_reader ya existe en 192.168.50.86 (lo creo grants-monitor.sql);
# usar su password. Ver data-mcp-servers/mssql/grants-intranet.sql
MSSQL_INTRANET_CONN=Server=192.168.50.86,1433;Database=INTRANET;User ID=mcp_reader;Password=<PASSWORD>;Encrypt=true;TrustServerCertificate=true

# ---------------------------------------------------------------------
# MCP Config Vault (import/export de configs sensibles, auth contra IAM)
# ---------------------------------------------------------------------
# Rutas del SERVIDOR (host), no del repo. El vault vive fuera de git y se
# respalda con el backup mensual (/opt/scripts/backup-machine.sh).
# VAULT_HOST_DIR: carpeta central donde viven los .env/certs/llaves a servir.
VAULT_HOST_DIR=/proyectos/_vault
# IAM_KEYS_DIR: carpeta con la llave publica del IAM (public.pem) para validar el JWT.
IAM_KEYS_DIR=/proyectos/ie-IAM/backend/keys
# IAM_BASE_URL: base del IAM para login() (por defecto https://iam.ie).
IAM_BASE_URL=https://iam.ie

# MySQL GLPI (sin uso todavia — descomentar contenedor en docker-compose.yml)
# MYSQL_GLPI_CONN=Server=<HOST>;Database=glpi;UserID=mcp_reader;Password=<PASSWORD>;SslMode=Preferred

# PostgreSQL OpenProject (sin uso todavia)
# PG_OPENPROJECT_CONN=Host=<HOST>;Port=5432;Database=openproject;Username=mcp_reader;Password=<PASSWORD>
