---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Info | MCP Server IE">
  <div class="docs-page">

    <!-- ── Intro ── -->
    <section class="docs-intro">
      <p class="docs-intro__eyebrow">INTEGRAL DE EMPAQUES</p>
      <h1 class="docs-intro__title">MCP Servers</h1>
      <p class="docs-intro__sub">
        Acceso estructurado a las bases de datos y documentación interna de IE
        a través del <strong>Model Context Protocol</strong>.
        Diseñado para agentes de IA y desarrolladores.
      </p>
      <div class="docs-intro__chips">
        <span class="docs-chip docs-chip--blue">SQL Server</span>
        <span class="docs-chip docs-chip--green">Solo lectura</span>
        <span class="docs-chip docs-chip--gray">LAN-only</span>
      </div>
    </section>

    <!-- ── Conexión rápida ── -->
    <section class="docs-section">
      <h2 class="docs-section__title">Cómo conectarse</h2>
      <p class="docs-section__text">
        Agrega los servers a tu cliente MCP (Claude Desktop, Claude Code, etc.):
      </p>
      <pre class="docs-code">{`{
  "mcpServers": {
    "ie-mssql": { "url": "http://mcp.ie/mssql/mcp" },
    "ie-monitor": { "url": "http://mcp.ie/monitor/mcp" },
    "ie-docs": { "url": "http://mcp.ie/docs/mcp" }
  }
}`}</pre>
    </section>

    <!-- ── Servers (dinámico) ── -->
    <section class="docs-section">
      <h2 class="docs-section__title">Servers disponibles</h2>
      <div id="servers-grid" class="servers-grid">
        <div class="servers-loading" id="servers-loading">
          <span class="loading-dot"></span>
          <span class="loading-dot"></span>
          <span class="loading-dot"></span>
          <span class="loading-label">Cargando configuración...</span>
        </div>
        <div class="servers-error" id="servers-error" style="display:none">
          <p class="servers-error__msg" id="servers-error-msg">
            No se pudo cargar la metadata de los servers.
          </p>
          <p class="servers-error__hint">
            Verifica que el servicio <code>mcp-docs-api</code> está corriendo:
            <code>docker compose ps mcp-docs-api</code>
          </p>
        </div>
      </div>
    </section>

    <!-- ── Troubleshooting ── -->
    <section class="docs-section docs-section--muted">
      <h2 class="docs-section__title">Troubleshooting</h2>
      <ul class="docs-list">
        <li>
          <strong>Los servers no aparecen:</strong> la API lee los
          <code>dab-config.json</code> del repositorio vía volumen Docker
          read-only montado en <code>/dab-configs</code>. Verifica con
          <code>docker compose ps mcp-docs-api</code>.
        </li>
        <li>
          <strong>Una entidad nueva no aparece:</strong> reconstruye el
          contenedor del MCP correspondiente:
          <code>docker compose up -d --build mcp-mssql-main</code>.
          El frontend no necesita rebuild.
        </li>
        <li>
          <strong>Los datos de conexión nunca son expuestos</strong> por esta
          API — ni connection strings, ni nombres de tablas internas, ni
          usuarios de BD.
        </li>
        <li>
          <strong>Documentación interna (para agentes):</strong>{" "}
          <a href="http://mcp.ie/docs/mcp" class="docs-link">mcp.ie/docs/mcp</a> —
          markdowns de lógica de negocio accesibles vía MCP.
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>

<script is:inline>
(function () {
  var TOOLS_LABELS = {
    read_records: "read",
    aggregate_records: "aggregate",
    create_record: "create",
    update_record: "update",
    delete_record: "delete",
    execute_entity: "execute",
    describe_entities: "describe",
  };

  function badge(text, active) {
    var el = document.createElement("span");
    el.className = "tool-badge" + (active ? " tool-badge--on" : " tool-badge--off");
    el.textContent = text;
    return el;
  }

  function entityPill(entity) {
    var pill = document.createElement("div");
    pill.className = "entity-pill";

    var name = document.createElement("span");
    name.className = "entity-pill__name";
    name.textContent = entity.name;

    var type = document.createElement("span");
    type.className = "entity-pill__type entity-pill__type--" + (entity.type || "table");
    type.textContent = entity.type || "table";

    pill.appendChild(name);
    pill.appendChild(type);

    if (entity.description) {
      pill.title = entity.description;
    }

    return pill;
  }

  function buildCard(server) {
    var card = document.createElement("div");
    card.className = "server-card" + (server.readonly ? " server-card--readonly" : " server-card--rw");

    // Header
    var header = document.createElement("div");
    header.className = "server-card__header";

    var titleRow = document.createElement("div");
    titleRow.className = "server-card__title-row";

    var title = document.createElement("h3");
    title.className = "server-card__title";
    title.textContent = server.label;

    var badge_rw = document.createElement("span");
    badge_rw.className = "server-card__badge " + (server.readonly ? "server-card__badge--ro" : "server-card__badge--rw");
    badge_rw.textContent = server.readonly ? "solo lectura" : "lectura + escritura";

    titleRow.appendChild(title);
    titleRow.appendChild(badge_rw);

    var desc = document.createElement("p");
    desc.className = "server-card__desc";
    desc.textContent = server.description || "";

    var url = document.createElement("p");
    url.className = "server-card__url";
    var urlLink = document.createElement("a");
    urlLink.className = "docs-link";
    urlLink.href = "http://mcp.ie/" + server.id + "/mcp";
    urlLink.textContent = "mcp.ie/" + server.id + "/mcp";
    url.appendChild(urlLink);

    header.appendChild(titleRow);
    header.appendChild(desc);
    header.appendChild(url);

    // Tools
    var toolsRow = document.createElement("div");
    toolsRow.className = "server-card__tools";
    var toolsLabel = document.createElement("span");
    toolsLabel.className = "server-card__tools-label";
    toolsLabel.textContent = "Tools:";
    toolsRow.appendChild(toolsLabel);

    if (server.tools) {
      Object.entries(server.tools).forEach(function(entry) {
        var key = entry[0];
        var active = entry[1];
        if (key === "describe_entities") return; // siempre activo, no hace ruido
        var label = TOOLS_LABELS[key] || key;
        toolsRow.appendChild(badge(label, active));
      });
    }

    // Entities
    var entitiesSection = document.createElement("div");
    entitiesSection.className = "server-card__entities";

    var entLabel = document.createElement("p");
    entLabel.className = "server-card__entities-label";
    entLabel.textContent = "Entidades (" + (server.entities ? server.entities.length : 0) + "):";
    entitiesSection.appendChild(entLabel);

    var pillsWrap = document.createElement("div");
    pillsWrap.className = "entity-pills";

    if (server.entities && server.entities.length) {
      server.entities.forEach(function (e) {
        pillsWrap.appendChild(entityPill(e));
      });
    }
    entitiesSection.appendChild(pillsWrap);

    card.appendChild(header);
    card.appendChild(toolsRow);
    card.appendChild(entitiesSection);
    return card;
  }

  function render(data) {
    var grid = document.getElementById("servers-grid");
    document.getElementById("servers-loading").style.display = "none";

    if (!data.servers || data.servers.length === 0) {
      var empty = document.createElement("p");
      empty.className = "servers-empty";
      empty.textContent = "No se encontraron servers configurados.";
      grid.appendChild(empty);
      return;
    }

    data.servers.forEach(function (server) {
      grid.appendChild(buildCard(server));
    });
  }

  function showError(msg) {
    document.getElementById("servers-loading").style.display = "none";
    var errEl = document.getElementById("servers-error");
    errEl.style.display = "block";
    document.getElementById("servers-error-msg").textContent = msg || "Error desconocido.";
  }

  fetch("/docs/api/servers")
    .then(function (res) {
      if (!res.ok) throw new Error("HTTP " + res.status);
      return res.json();
    })
    .then(render)
    .catch(function (err) {
      showError("No se pudo cargar la metadata: " + err.message);
    });
})();
</script>
</BaseLayout>
