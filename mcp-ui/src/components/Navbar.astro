---
const { pathname } = Astro.url;
const isHome = pathname === "/";
const isDocs = pathname.startsWith("/docs");
---
<!--
  Tesla-style navbar: logo izq | links centrados (absolutos) | slot derecho vacío.
  Translúcido con blur — sin fondo sólido.
-->
<nav class="navbar">
  <a class="navbar__brand" href="/">
    <span class="navbar__icon" aria-hidden="true">
      <img src="/assets/logo.png" alt="Integral de Empaques" width="28" height="28" decoding="async" />
    </span>
    <span class="navbar__name">Integral de Empaques</span>
  </a>

  <!-- Links centrados con position absolute -->
  <div class="navbar__links">
    <a class={isHome ? "active" : ""} href="/">Home</a>
    <a class={isDocs ? "active" : ""} href="/docs">Docs</a>
  </div>

  <!-- Slot derecho — balanceo visual -->
  <div class="navbar__right">
    <a class="navbar__doc-btn" href="/docs">Documentation</a>
  </div>
</nav>
