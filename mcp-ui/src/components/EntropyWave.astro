<!--
  SVG grain filter — desplazamiento suave de los bordes (sandy feel).
  Aplicado al canvas vía CSS filter: url(#grain).
-->
<svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
  <defs>
    <filter id="grain" x="-5%" y="-5%" width="110%" height="110%"
            color-interpolation-filters="linearRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.70 0.65"
                    numOctaves="3" seed="5" stitchTiles="stitch" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise"
                         scale="4" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<div class="entropy-wave">
  <canvas id="entropy-canvas" class="entropy-wave__canvas" aria-hidden="true"></canvas>
</div>

<script is:inline>
(function () {
  var canvas = document.getElementById("entropy-canvas");
  if (!canvas || canvas.dataset.ready) return;
  canvas.dataset.ready = "true";

  var ctx = canvas.getContext("2d");
  var frame = 0;
  var seed  = Math.floor(Math.random() * 9999);

  /* ── Value noise 3-D ── */
  function hash(x, y, z) {
    var n = Math.sin(x * 127.1 + y * 311.7 + z * 74.3) * 43758.5453;
    return n - Math.floor(n);
  }
  function fade(t) { return t * t * (3 - 2 * t); }
  function lerpF(a, b, t) { return a + (b - a) * t; }
  function noise(x, y, z) {
    var ix = Math.floor(x), iy = Math.floor(y), iz = Math.floor(z);
    var fx = fade(x-ix), fy = fade(y-iy), fz = fade(z-iz);
    return lerpF(
      lerpF(lerpF(hash(ix,iy,iz),   hash(ix+1,iy,iz),   fx),
            lerpF(hash(ix,iy+1,iz), hash(ix+1,iy+1,iz), fx), fy),
      lerpF(lerpF(hash(ix,iy,iz+1),   hash(ix+1,iy,iz+1),   fx),
            lerpF(hash(ix,iy+1,iz+1), hash(ix+1,iy+1,iz+1), fx), fy),
      fz
    );
  }

  /* ── Color interpolation: navy → electric-blue → green ──
     mix ∈ [0,1]:  0 = dark navy,  0.5 = electric blue,  1 = green     */
  function strokeColor(mix, alpha) {
    var r, g, b;
    if (mix < 0.5) {
      var m = mix * 2;               // 0→1 across first half
      r = Math.round(1   + (35-1)   * m);  //   1 → 35
      g = Math.round(20  + (155-20) * m);  //  20 → 155
      b = Math.round(128 + (216-128)* m);  // 128 → 216
    } else {
      var m = (mix - 0.5) * 2;       // 0→1 across second half
      r = Math.round(35  + (2-35)   * m);  //  35 → 2
      g = Math.round(155 + (159-155)* m);  // 155 → 159
      b = Math.round(216 + (76-216) * m);  // 216 → 76
    }
    return "rgba("+r+","+g+","+b+","+alpha.toFixed(3)+")";
  }

  function resize() {
    var p = canvas.parentElement;
    canvas.width  = p.clientWidth  || 900;
    canvas.height = p.clientHeight || 420;
  }
  resize();
  window.addEventListener("resize", resize);

  var LAYERS     = 72;    // dense ribbon — more layers = richer texture
  var ANGLE_STEP = 0.045; // ~140 vertices per ring → smooth curve
  var TWO_PI     = Math.PI * 2;

  function draw() {
    var w = canvas.width, h = canvas.height;
    var cx = w * 0.5, cy = h * 0.5;
    /* Base radius: ~32% of shortest side; noise & wave add ±25% on top */
    var baseR = Math.min(w, h) * 0.30;
    var t = frame * 0.005; // animation speed

    ctx.clearRect(0, 0, w, h);
    /* Faint white trail → motion blur effect without extra canvas */
    ctx.fillStyle = "rgba(255,255,255,0.18)";
    ctx.fillRect(0, 0, w, h);

    for (var layer = 0; layer < LAYERS; layer++) {
      var mix   = layer / (LAYERS - 1);          // 0 → 1
      /* Each layer gets its own noise "slice" in z */
      var tOff  = t + layer * 0.055;
      /* Alpha: slightly higher in the mid-layers (gives volume) */
      var alpha = 0.28 + 0.18 * Math.sin(mix * Math.PI);

      ctx.beginPath();
      ctx.strokeStyle = strokeColor(mix, alpha);
      ctx.lineWidth   = 1.0;

      var started = false;
      for (var a = 0; a <= TWO_PI + ANGLE_STEP; a += ANGLE_STEP) {
        /* Organic noise: sample at point on unit circle rotated by seed */
        var nx = Math.cos(a) + seed * 0.001;
        var ny = Math.sin(a) + seed * 0.002;
        var nv = noise(nx, ny, tOff);

        /* Wave distortion: 3 harmonics for complex shape */
        var wave  =  Math.sin(a * 3 + t * 1.8 + layer * 0.12) * 14
                   + Math.sin(a * 5 + t * 1.1 - layer * 0.07) *  6
                   + Math.sin(a * 2 - t * 0.9 + layer * 0.05) *  8;

        var radius = baseR + nv * 110 + wave;

        /* Slight vertical squeeze → elliptical / perspective feel */
        var x = cx + Math.cos(a) * radius;
        var y = cy + Math.sin(a) * radius * 0.82;

        if (!started) { ctx.moveTo(x, y); started = true; }
        else           { ctx.lineTo(x, y); }
      }
      ctx.stroke();
    }

    frame++;
    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);
})();
</script>
