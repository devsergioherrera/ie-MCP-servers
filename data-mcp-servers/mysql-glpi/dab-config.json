{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mysql",
    "connection-string": "@env('MYSQL_GLPI_CONN')"
  },
  "runtime": {
    "host": {
      "mode": "production",
      "cors": {
        "origins": [],
        "allow-credentials": false
      }
    },
    "rest": { "enabled": false },
    "graphql": { "enabled": false },
    "mcp": {
      "enabled": true,
      "path": "/mcp",
      "dml-tools": {
        "describe-entities": true,
        "read-records": true,
        "aggregate-records": true,
        "create-record": false,
        "update-record": false,
        "delete-record": false,
        "execute-entity": false
      },
      "description": "MCP de solo lectura sobre MySQL de GLPI (sistema de tickets de Integral de Empaques). SCAFFOLDING - sin entidades expuestas todavia."
    }
  },
  "entities": {}
}
