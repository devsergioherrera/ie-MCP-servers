{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('MSSQL_INTRANET_CONN')",
    "options": { "set-session-context": false }
  },
  "runtime": {
    "host": { "mode": "production", "cors": { "origins": [], "allow-credentials": false } },
    "rest": { "enabled": false },
    "graphql": { "enabled": false },
    "mcp": {
      "enabled": true,
      "path": "/mcp",
      "dml-tools": {
        "describe-entities": true,
        "read-records": true,
        "aggregate-records": true,
        "create-record": false,
        "update-record": false,
        "delete-record": false,
        "execute-entity": false
      },
      "description": "MCP de SOLO LECTURA sobre la BD INTRANET (192.168.50.86). PLACEHHOLDER: regenerar con gen-config.py para poblar las entidades reales antes de desplegar."
    }
  },
  "entities": {}
}
